{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "780px",
			"wideSize": "1100px"
		},
		"color": {
			"palette": [
				{ "slug": "base", "color": "#ffffff", "name": "Base" },
				{ "slug": "contrast", "color": "#1a1a1a", "name": "Contrast" },
				{ "slug": "primary", "color": "#0f766e", "name": "Primary" },
				{ "slug": "accent", "color": "#f59e0b", "name": "Accent" },
				{ "slug": "muted", "color": "#6b7280", "name": "Muted" },
				{ "slug": "surface", "color": "#f6f7f9", "name": "Surface" }
			]
		},
		"typography": {
			"fluid": true,
			"fontFamilies": [
				{
					"slug": "system",
					"name": "System",
					"fontFamily": "-apple-system, BlinkMacSystemFont, 'Hiragino Sans', 'Noto Sans JP', 'Yu Gothic', Meiryo, sans-serif"
				}
			],
			"fontSizes": [
				{ "slug": "small", "size": "0.875rem", "name": "Small" },
				{ "slug": "medium", "size": "1rem", "name": "Medium" },
				{ "slug": "large", "size": "1.375rem", "name": "Large" },
				{ "slug": "x-large", "size": "2rem", "name": "X-Large" }
			]
		},
		"spacing": {
			"units": ["px", "em", "rem", "%", "vw"]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--system)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.75"
		},
		"elements": {
			"link": {
				"color": { "text": "var(--wp--preset--color--primary)" }
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--accent)",
					"text": "var(--wp--preset--color--contrast)"
				}
			}
		}
	},
	"templateParts": [
		{ "name": "header", "title": "ヘッダー", "area": "header" },
		{ "name": "footer", "title": "フッター", "area": "footer" }
	]
}
